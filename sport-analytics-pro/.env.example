# ============================================
# Variables d'environnement — Production
# Copier en .env sur l'EC2 (ne jamais commiter)
# ============================================

NODE_ENV=production
PORT=3000

# --- Base de donnees (RDS Postgres Free Tier) ---
DATABASE_URL=postgresql://sportuser:VOTRE_MDP@VOTRE-RDS.xxx.rds.amazonaws.com:5432/sport_analytics

# --- API Sports (api-sports.io) ---
API_SPORTS_KEY=votre_cle_api_sports

# --- JWT ---
# Generer: openssl rand -base64 48
JWT_SECRET=remplacez_par_une_chaine_aleatoire_longue_48_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Mettre le domaine du frontend en prod. "*" pour tester.
CORS_ORIGIN=*

# --- Optionnel (desactive par defaut sur free tier) ---
# REDIS_URL=redis://localhost:6379
